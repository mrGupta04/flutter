# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Public URL for uploaded files (use your LAN IP when testing on a physical phone)
# PUBLIC_BASE_URL=http://10.12.67.190:3000

# MongoDB Atlas — required
# 1. Create free cluster at https://cloud.mongodb.com
# 2. Database Access → create user
# 3. Network Access → add your IP (or 0.0.0.0/0 for dev)
# 4. Connect → Drivers → copy connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/1mg_doctors?retryWrites=true&w=majority

# If npm start fails with querySrv ECONNREFUSED, use Standard connection string from Atlas:
# MONGODB_URI_DIRECT=mongodb://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net:27017/1mg_doctors?ssl=true&directConnection=true

# Security — CHANGE ALL SECRETS IN PRODUCTION
JWT_SECRET=replace-with-random-64-char-secret-minimum-32-chars-required
ADMIN_API_KEY=optional-legacy-api-key-header

# Main admin login (POST /api/v1/admin/login)
ADMIN_EMAIL=admin@1mgdoctors.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# Optional: seed sample doctors on startup
SEED_DATABASE=false

# --- Real UIDAI OTP (via licensed KYC partner — Surepass) ---
# Direct UIDAI API requires AUA/KUA registration with UIDAI. For production apps use Surepass:
# 1. Sign up: https://surepass.io/get-api-key/
# 2. Set token below and AADHAAR_PROVIDER=surepass
AADHAAR_PROVIDER=surepass
SUREPASS_API_TOKEN=your_surepass_bearer_token
SUREPASS_API_BASE=https://sandbox.surepass.io/api/v1
# Production: SUREPASS_API_BASE=https://kyc-api.surepass.app/api/v1
# SUREPASS_GENERATE_OTP_PATH=/aadhaar-v2/generate-otp
# SUREPASS_SUBMIT_OTP_PATH=/aadhaar-v2/submit-otp

# Development fallback only (OTP is NOT from UIDAI):
# AADHAAR_PROVIDER=mock
# AADHAAR_OTP_DEV_MODE=true

# --- Doctor email verification — Gmail ---
# OTP is emailed to the address entered during doctor registration.
# Without SMTP vars below, the API uses mock mode locally (OTP logged in server console).
# Setup for real email:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-character password as SMTP_PASS (no spaces)
# On Render: upgrade to a paid instance (free tier blocks SMTP ports 25/465/587).
EMAIL_PROVIDER=smtp
APP_NAME=MedConnect Doctors
SMTP_SERVICE=gmail
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your@gmail.com
SMTP_FROM_NAME=MedConnect Doctors

# Alternative: explicit host (port 465 often more reliable than 587)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_TIMEOUT_MS=20000

# Render / production
# NODE_ENV=production

# Local development only — logs OTP instead of sending email:
# EMAIL_PROVIDER=mock

# --- Booking payments — Razorpay ---
# Default is mock (no keys needed). Bookings auto-confirm after a simulated payment.
# When ready for production:
#   RAZORPAY_PROVIDER=razorpay
#   RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
#   RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_PROVIDER=mock
# PAYMENT_HOLD_MINUTES=15

# --- Online consult video calls ---
# mock = in-app demo call UI (default). jitsi = embed Jitsi Meet. agora = Agora RTC (recommended).
VIDEO_PROVIDER=agora
# Minutes before slotStart when Join is enabled (default 10)
# VIDEO_JOIN_EARLY_MINUTES=10
# Minutes after slotEnd when Join stays enabled (default 5)
# VIDEO_JOIN_GRACE_MINUTES=5
# JITSI_MEET_BASE_URL=https://meet.jit.si

# --- Agora RTC (https://console.agora.io) ---
# Create a project, copy App ID and App Certificate. Enable "Testing mode" if no certificate yet.
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
# AGORA_TOKEN_TTL_SECONDS=3600

# Meeting links sent in booking confirmation emails/SMS (bookingId is appended)
# PATIENT_MEETING_LINK_PREFIX=medconnect://video-consult?bookingId=
# DOCTOR_MEETING_LINK_PREFIX=medconnect-doctor://video-consult?bookingId=
